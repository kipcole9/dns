; A zone full of TXT records — every shape an operator typically
; needs (SPF, DKIM, DMARC, MTA-STS, _acme-challenge, plain markers).
; The point of this fixture is to confirm the parser handles `;`,
; `=`, long base64 values, and `@`/`:`/`-` inside quoted strings.

$TTL 3600
$ORIGIN mail.test.

@   IN SOA ns.mail.test. h.mail.test. ( 1 7200 3600 1209600 3600 )
    IN NS  ns.mail.test.
ns  IN A   192.0.2.40

; ----- SPF (semicolon and `-` inside the quote) --------------

@ IN TXT "v=spf1 ip4:192.0.2.0/24 -all"

; ----- DKIM (long base64 with `+`, `/`, `=`) -----------------

selector1._domainkey IN TXT "v=DKIM1; k=rsa; p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQDXEUuwx2bZwK4ZVeF0yMl3Q9ULyZxgUHC7Nz1xJ7"

; ----- DMARC (multiple `;` and `mailto:` URI) ----------------

_dmarc IN TXT "v=DMARC1; p=quarantine; pct=100; rua=mailto:dmarc-rua@mail.test; ruf=mailto:dmarc-ruf@mail.test; fo=1"

; ----- MTA-STS policy id (semicolon-separated key=value) -----

_mta-sts IN TXT "v=STSv1; id=2026050601"

; ----- ACME DNS-01 challenge token ---------------------------

_acme-challenge IN TXT "tokenAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"

; ----- Plain marker (zero punctuation in the quote) ----------

@ IN TXT "exdns-marker iteration=1"
